{
  "name": "pisci-desktop",
  "version": "0.8.31",
  "private": true,
  "type": "module",
  "scripts": {
    "icon:emoji": "node scripts/emoji-to-png.mjs && tauri icon fish-emoji-512.png",
    "dev": "vite",
    "build": "npm run build:web",
    "build:web": "tsc && vite build",
    "build:headless": "cargo build -p pisci-cli --release --bin openpisci-headless --manifest-path src-tauri/Cargo.toml",
    "build:tauri": "npm run build:web",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@reduxjs/toolkit": "^2.3.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.3",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "@tauri-apps/plugin-notification": "^2.0.1",
    "@tauri-apps/plugin-shell": "^2.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.13",
    "mermaid": "^11.12.3",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.1.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.0.18"
  }
}
